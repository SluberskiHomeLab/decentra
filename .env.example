# PostgreSQL Database Configuration
POSTGRES_DB=decentra
POSTGRES_USER=decentra
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE

# Encryption Configuration
# REQUIRED: Generate a strong encryption key for sensitive data encryption
# Generate a key using: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
DECENTRA_ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# Security Configuration
# Optional: Set the base URL for password reset emails (default: https://localhost:8765)
# DECENTRA_BASE_URL=https://your-domain.com

# DATABASE_URL is automatically constructed from the PostgreSQL variables above
# You can optionally override it by uncommenting and setting the line below:
# DATABASE_URL=postgresql://decentra:your_custom_password@postgres:5432/decentra
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# License Configuration
# Optional: Set your Decentra license key to unlock premium features
# Generate a license key using: python tools/license/create_license.py
# DECENTRA_LICENSE_KEY=

# ── Coturn TURN Relay ─────────────────────────────────────────────────
# Required for voice/video calls.  The shared secret must match the
# value in coturn/coturn.conf.  Generate a strong secret using:
#   python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
COTURN_SECRET=YOUR_COTURN_SECRET_HERE
COTURN_URL=turn:localhost:3478
COTURN_REALM=decentra.local